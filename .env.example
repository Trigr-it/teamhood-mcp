# Teamhood API credentials
TEAMHOOD_API_KEY=your-api-key-here

# Tenant-specific base URL: https://api-YOURTENANT.teamhood.com
# Your tenant name is in your Teamhood URL (e.g. "node" from node.teamhood.com)
TEAMHOOD_API_BASE_URL=https://api-node.teamhood.com

# Teamhood IDs (run "node discover-ids.js" to find these)
TEAMHOOD_WORKSPACE_ID=your-workspace-uuid
TEAMHOOD_BOARD_ID=your-board-uuid

# Zoho Invoice API (for dashboard — copy from Zoho-Plug .env)
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_TOKEN_URL=https://accounts.zoho.eu/oauth/v2/token
ZOHO_API_BASE=https://www.zohoapis.eu/invoice/v3

# Path to quote reference DB (default: ../Zoho-Plug/quote_reference_db.json)
# QUOTE_DB_PATH=

# Server
PORT=3000
